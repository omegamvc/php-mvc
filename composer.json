{
    "name": "omegamvc/php-mvc",
    "description": "Very light php mvc, include cli easier to create controller view and model quickly ",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Adriano Giovannini",
            "email": "agisoftt@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-http": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pcntl": "*",
        "ext-pdo": "*",
        "ext-posix": "*",
        "ext-readline": "*",
        "omegamvc/php-library": "^1.0.0",
        "vlucas/phpdotenv": "^5.6.1",
        "react/event-loop": "^1.5.0",
    },
    "require-dev": {
        "filp/whoops": "^2.17.0",
        "squizlabs/php_codesniffer": "^3.11.3"
    },
    "autoload": {
        "psr-4": {
            "App\\" : "app",
            "Database\\Seeders\\": "database/seeders/",
            "": [
                "app/library/",
                "app/services/"
            ]
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
